{
  "name": "www",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun x astro dev",
    "build": "bun x astro build",
    "preview": "bun x astro preview",
    "db:push": "bun x drizzle-kit push",
    "db:seed": "bun scripts/db/seed.ts",
    "db:studio": "bun x drizzle-kit studio",
    "alchemy:configure": "bun x alchemy configure",
    "alchemy:dev": "bun x alchemy dev --env-file .env",
    "alchemy:login": "bun x alchemy login",
    "deploy": "bun x alchemy deploy --env-file .env",
    "destroy": "bun x alchemy destroy --env-file .env",
    "✨": "──────────────── Hygiene ────────────────",
    "lint": "bun x eslint \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "lint:fix": "bun x eslint \"src/**/*.{js,ts,jsx,tsx,astro}\" --fix",
    "format": "bun x prettier --write \"src/**/*.{js,ts,jsx,tsx,astro,md,mdx,json}\"",
    "check-types": "bun x astro check",
    "new": "bun src/content/_scripts/new-post.ts",
    "update:deps": "bash ./update-deps.sh"
  },
  "dependencies": {
    "@alpinejs/focus": "^3.15.12",
    "@astrojs/alpinejs": "^1.0.0",
    "@libsql/client": "^0.17.4",
    "@octokit/rest": "^22.0.1",
    "@shikijs/transformers": "^4.3.0",
    "@tursodatabase/serverless": "^1.2.3",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12",
    "astro": "7.0.5",
    "astro-icon": "^1.1.5",
    "astro-robots-txt": "^1.0.0",
    "astro-theme-toggle": "^0.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "rehype-pretty-code": "^0.14.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "7.0.1",
    "@astrojs/node": "^11.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "^1.10.9",
    "@astrojs/vercel": "11.0.1",
    "alchemy": "^0.93.12",
    "@iconify-json/arcticons": "^1.2.54",
    "@iconify-json/lucide": "^1.2.115",
    "@tailwindcss/vite": "^4.3.2",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
