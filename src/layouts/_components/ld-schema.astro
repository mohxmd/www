---
/* eslint-disable astro/no-set-html-directive */

import { siteConfig } from "#/configs/site";

type Props = {
  type: "blog" | "website";
  title: string;
  description: string;
  pageUrl: string;
  ogImageUrl?: string | null;
  publishDate?: string;
  modifiedDate?: string;
};

const { type, title, description, pageUrl, ogImageUrl, publishDate, modifiedDate } = Astro.props;

const siteUrl = siteConfig.site.replace(/\/+$/, "");
const personId = `${siteUrl}/#person`;
const websiteId = `${siteUrl}/#website`;
const webpageId = `${pageUrl}/#webpage`;
const articleId = `${pageUrl}/#blogposting`;
const sameAs = siteConfig.contacts
  .map((contact) => contact.href)
  .filter((href) => href.startsWith("https://"));

const author = {
  "@type": "Person",
  "@id": personId,
  name: siteConfig.author,
  url: `${siteUrl}/about`,
  sameAs,
};

const website = {
  "@type": "WebSite",
  "@id": websiteId,
  url: siteUrl,
  name: siteConfig.title,
  description: siteConfig.description,
  inLanguage: "en-US",
  publisher: { "@id": personId },
};

const baseMetadata = {
  "@id": webpageId,
  url: pageUrl,
  inLanguage: "en-US",
  isPartOf: { "@id": websiteId },
  name: title,
  description,
  author: { "@id": personId },
  publisher: { "@id": personId },
  ...(ogImageUrl
    ? {
        image: {
          "@type": "ImageObject",
          url: ogImageUrl,
          width: 1280,
          height: 675,
        },
      }
    : {}),
};

const blogPostingSchema = {
  ...baseMetadata,
  "@type": "BlogPosting",
  "@id": articleId,
  headline: title,
  datePublished: publishDate,
  dateModified: modifiedDate || publishDate,
  mainEntityOfPage: { "@id": webpageId },
};

const webPageSchema = {
  ...baseMetadata,
  "@type": "WebPage",
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [author, website, type === "blog" ? blogPostingSchema : webPageSchema],
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
