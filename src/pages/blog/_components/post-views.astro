---
export const prerender = false;

import type { ComponentProps } from "astro/types";
import type { CollectionEntry } from "astro:content";
import { sql } from "drizzle-orm";
import { getDb, postView } from "#/db";

import Number from "#/components/ui/number.astro";

type Props = Omit<ComponentProps<typeof Number>, "value"> & Pick<CollectionEntry<"blog">, "id">;

const { id, ...props } = Astro.props;
const views = await getDb()
  .then((db) =>
    db
      .insert(postView)
      .values({ post: id, views: 1 })
      .onConflictDoUpdate({
        target: postView.post,
        set: { views: sql`${postView.views} + 1` },
      })
      .returning({ views: postView.views })
      .get()
  )
  .then((res) => res?.views ?? 0)
  .catch((error) => {
    // eslint-disable-next-line no-console
    console.warn(
      `Skipping post views update for ${id}: ${error instanceof Error ? error.message : "Unknown error"}`
    );
    return 0;
  });
---

<Number {...props} value={views}> Views</Number>
